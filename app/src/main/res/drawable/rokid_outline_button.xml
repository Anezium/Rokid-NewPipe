<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="#22000000" />
            <stroke
                android:width="2dp"
                android:color="#FFFFFFFF" />
            <padding
                android:left="6dp"
                android:top="4dp"
                android:right="6dp"
                android:bottom="4dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <solid android:color="#22000000" />
            <stroke
                android:width="2dp"
                android:color="#FFFFFFFF" />
            <padding
                android:left="6dp"
                android:top="4dp"
                android:right="6dp"
                android:bottom="4dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#22FFFFFF" />
            <stroke
                android:width="2dp"
                android:color="#FFFFFFFF" />
            <padding
                android:left="6dp"
                android:top="4dp"
                android:right="6dp"
                android:bottom="4dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1.5dp"
                android:color="#CCFFFFFF" />
            <padding
                android:left="6dp"
                android:top="4dp"
                android:right="6dp"
                android:bottom="4dp" />
        </shape>
    </item>
</selector>
