<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".DebugApp"
        tools:replace="android:name">
        <receiver
            android:name=".DebugRokidStateReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.anezium.rokid.newpipe.debug.DUMP_ROKID_STATE" />
                <action android:name="com.anezium.rokid.newpipe.debug.RESET_ROKID_STATE" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
